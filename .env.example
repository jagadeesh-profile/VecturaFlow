# ─────────────────────────────────────────────────────────────────────────────
# VecturaFlow — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Pinecone ─────────────────────────────────────────────────────────────────
PINECONE_API_KEY=pcsk_...
PINECONE_INDEX=vecturaflow
PINECONE_REGION=us-east-1

# ── AWS Core ─────────────────────────────────────────────────────────────────
AWS_DEFAULT_REGION=us-east-1
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...

# ── AWS Resource Names ────────────────────────────────────────────────────────
INGESTION_BUCKET=vecturaflow-ingestion-dev
INGESTION_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/ACCOUNT_ID/vecturaflow-ingestion
EMBEDDING_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/ACCOUNT_ID/vecturaflow-embedding
REGISTRY_TABLE=vecturaflow-registry
KEYS_TABLE=vecturaflow-keys

# ── Redis (ElastiCache or local) ──────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ── API Config ────────────────────────────────────────────────────────────────
API_ENV=development
API_DEBUG=true
API_TITLE=VecturaFlow API
API_VERSION=1.0.0

# ── RAG Config ────────────────────────────────────────────────────────────────
RETRIEVAL_TOP_K=5
RETRIEVAL_SCORE_THRESHOLD=0.70
CHUNK_SIZE=512
CHUNK_OVERLAP=50
EMBEDDING_MODEL=text-embedding-3-small
GENERATION_MODEL=gpt-4o-mini
